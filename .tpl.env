# Шаблон локальной конфигурации PipelineAI. На основе этого файла создаётся .env
# Все переменные описаны с рекомендуемыми значениями по умолчанию.

APP_NAME=pipelineai
ENV=dev

# Минимальные настройки логгера (см. internal/logger).
LOG_LEVEL=INFO

# Базовый URL OpenAI-совместимого API (например, http://localhost:1234/v1)
# Примеры:
# - LM Studio: http://localhost:1234/v1
# - vLLM:      http://localhost:8000/v1
LLM_BASE_URL=http://localhost:1234/v1
# API-ключ для доступа к локальному или удалённому LLM. Для локального рантайма может быть пустым.
LLM_API_KEY=
# Имя модели, которую следует использовать по умолчанию.
LLM_MODEL=openai/gpt-oss-20b
# Таймаут запроса к LLM в формате duration (например, 30s, 1m).
LLM_REQUEST_TIMEOUT=30s
DEFAULT_TOOL_TIMEOUT=60s
