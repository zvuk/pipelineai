# Шаблон локальной конфигурации PipelineAI. На основе этого файла создаётся .env
# Все переменные описаны с рекомендуемыми значениями по умолчанию.

APP_NAME=pipelineai
ENV=dev

# Минимальные настройки логгера (см. internal/logger).
LOG_LEVEL=INFO

# Базовый URL OpenAI-совместимого API (например, http://localhost:1234/v1)
# Примеры:
# - LM Studio: http://localhost:1234/v1
# - vLLM:      http://localhost:8000/v1
LLM_BASE_URL=http://localhost:1234/v1
# API-ключ для доступа к локальному или удалённому LLM. Для локального рантайма может быть пустым.
LLM_API_KEY=
# Имя модели, которую следует использовать по умолчанию.
LLM_MODEL=openai/gpt-oss-20b
# Таймаут запроса к LLM в формате duration (например, 30s, 1m).
LLM_REQUEST_TIMEOUT=30s
DEFAULT_TOOL_TIMEOUT=60s

# Метрики PipelineAI. По умолчанию выключены.
# Для Prometheus Pushgateway-compatible endpoint:
# PAI_METRICS_ENABLED=true
# PAI_METRICS_PUSHGATEWAY_URL=http://localhost:9091
# PAI_METRICS_PUSHGATEWAY_JOB=pipelineai
# Для Prometheus remote_write endpoint:
# PAI_METRICS_REMOTE_WRITE_URL=http://localhost:8428/api/v1/write
# Локальный Prometheus text artifact:
# PAI_METRICS_FILE=.agent/artifacts/metrics/pipelineai.prom
PAI_METRICS_ENABLED=false
PAI_METRICS_PUSHGATEWAY_URL=
PAI_METRICS_PUSHGATEWAY_JOB=pipelineai
PAI_METRICS_REMOTE_WRITE_URL=
PAI_METRICS_TIMEOUT=5s
PAI_METRICS_LABELS=
PAI_METRICS_GROUPING_LABELS=
PAI_METRICS_GROUP_BY_RUN=true
PAI_METRICS_FILE=
PAI_METRICS_EXTRA_JSON=
